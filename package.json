{
  "name": "valuetracker",
  "version": "1.2.0",
  "description": "Parttracker BV — ValueTracker surplus inventory valuation tool",
  "author": "Parttracker BV",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "npm run build && electron-builder --win",
    "electron:publish": "npm run build && electron-builder --win --publish always"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/formidable": "^3.4.7",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "formidable": "^3.5.4",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.575.0",
    "next": "^15.1.12",
    "node-llama-cpp": "^3.16.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "styled-jsx": "^5.1.7",
    "tailwind-merge": "^3.5.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "^15.1.12",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^8.0.5"
  }
